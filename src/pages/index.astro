---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { STAGES, gradeLabel } from "../lib/grades";
import { getGradeCounts, getOtherPlatforms } from "../lib/catalog";
import strLuftfoto from "../assets/str_luftfoto.jpg";

const counts = await getGradeCounts();
const otherCount = (await getOtherPlatforms()).length;

const STAGE_COLS: Record<string, string> = {
  indskoling: "lg:grid-cols-4",
  mellemtrin: "lg:grid-cols-3",
  udskoling: "lg:grid-cols-3",
};

function platformLabel(count: number): string {
  return count === 1 ? "1 platform" : `${count} platforme`;
}
---

<Layout title="Digitale Læremidler – Oversigt">
  <!-- Hero: anchored in the school itself + the wayfinding purpose -->
  <section class="flex flex-col gap-6">
    <div class="flex flex-col gap-4">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-green-deep">
        STR · Digitale læremidler
      </p>
      <h1
        class="max-w-2xl font-display text-3xl font-bold leading-tight tracking-tight text-ink sm:text-4xl lg:text-5xl"
      >
        Find de rette digitale læremidler til din klasse
      </h1>
      <p class="max-w-xl text-base leading-relaxed text-ink-soft">
        Vælg en årgang og se de platforme, der er klar til dine elever — samlet
        ét sted, så du hurtigt kommer videre til undervisningen.
      </p>
    </div>

    <div class="overflow-hidden rounded-2xl border border-line shadow-sm">
      <Image
        src={strLuftfoto}
        alt="Luftfoto af STR"
        width={1400}
        height={325}
        widths={[640, 980, 1400]}
        sizes="(min-width: 1024px) 1100px, 100vw"
        loading="eager"
        fetchpriority="high"
        class="h-44 w-full object-cover object-center sm:h-56 lg:h-64"
      />
    </div>
  </section>

  <!-- The grade index: the signature wayfinding device, by folkeskole stage -->
  <section class="mt-12 flex flex-col gap-8" aria-labelledby="vaelg-aargang">
    <h2 id="vaelg-aargang" class="font-display text-xl font-semibold text-ink">
      Vælg årgang
    </h2>

    {
      STAGES.map((stage) => (
        <div class="flex flex-col gap-3">
          <div class="flex items-baseline gap-2">
            <h3 class="text-sm font-semibold uppercase tracking-wide text-ink-soft">
              {stage.label}
            </h3>
            <span class="text-xs text-ink-faint">
              {stage.grades[0]}.–{stage.grades[stage.grades.length - 1]}. årgang
            </span>
          </div>
          <ul class:list={["grid grid-cols-2 gap-3 sm:grid-cols-3", STAGE_COLS[stage.key]]}>
            {stage.grades.map((grade) => (
              <li>
                <a
                  href={`/grade/${grade}`}
                  class="u-card group flex h-full items-center gap-3 p-4 transition-all duration-200 hover:(-translate-y-0.5 border-green/45 shadow-[0_12px_30px_-14px_rgba(20,33,26,0.3)])"
                >
                  <span class="font-display text-3xl font-bold tabular-nums text-green-deep">
                    {grade}
                  </span>
                  <span class="flex min-w-0 flex-col">
                    <span class="font-semibold text-ink">{gradeLabel(grade)}</span>
                    <span class="text-sm text-ink-soft">
                      {platformLabel(counts[grade] ?? 0)}
                    </span>
                  </span>
                  <span
                    class="i-ph-arrow-right ml-auto text-ink-faint transition-transform duration-200 group-hover:(translate-x-0.5 text-green-deep)"
                    aria-hidden="true"
                  />
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </section>

  <!-- Other platforms (no grade binding) -->
  <section class="mt-12">
    <a
      href="/other"
      class="u-card group flex items-center gap-4 p-5 transition-all duration-200 hover:(-translate-y-0.5 border-green/45 shadow-[0_12px_30px_-14px_rgba(20,33,26,0.3)])"
    >
      <span
        class="grid size-11 shrink-0 place-items-center rounded-xl bg-green-wash"
        aria-hidden="true"
      >
        <span class="i-ph-squares-four-fill text-xl text-green-deep"></span>
      </span>
      <span class="flex min-w-0 flex-col">
        <span class="font-display font-semibold text-ink">Andre platforme</span>
        <span class="text-sm text-ink-soft">
          Øvrige digitale ressourcer på tværs af fag · {platformLabel(otherCount)}
        </span>
      </span>
      <span
        class="i-ph-arrow-right ml-auto text-ink-faint transition-transform duration-200 group-hover:(translate-x-0.5 text-green-deep)"
        aria-hidden="true"
      ></span>
    </a>
  </section>
</Layout>
