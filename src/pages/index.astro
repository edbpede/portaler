---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import GradeRail from "../components/GradeRail.astro";
import SubjectTiles from "../components/SubjectTiles.astro";
import aerial from "../assets/str_luftfoto.jpg";
---

<Layout title="Digitale læremidler — STR">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    {/* Hero — the school, and the one thing this page is for. */}
    <section class="relative mt-6 overflow-hidden rounded-3xl">
      <Image
        src={aerial}
        alt="Luftfoto af skolen"
        widths={[640, 960, 1280, 1600]}
        sizes="(min-width: 1152px) 1100px, 100vw"
        loading="eager"
        fetchpriority="high"
        class="h-[280px] w-full object-cover object-center sm:h-[360px]"
      />
      <div
        class="absolute inset-0 bg-linear-to-t from-black/75 via-black/35 to-black/10"
        aria-hidden="true"
      >
      </div>
      <div class="absolute inset-0 flex flex-col justify-end p-6 sm:p-10">
        <p class="mb-2 text-sm font-medium tracking-wide text-white/80 uppercase">
          STR · Skolens platforme
        </p>
        <h1 class="font-display text-3xl font-bold leading-tight text-white sm:text-5xl">
          Find skolens digitale læremidler
        </h1>
        <p class="mt-3 max-w-xl text-base text-white/85 sm:text-lg">
          Alle vores platforme, e-bøger og portaler — samlet ét sted og sorteret
          efter klassetrin og fag.
        </p>
      </div>
    </section>

    {/* Primary navigation: the school journey, 0.–9. klasse. */}
    <section class="py-12 sm:py-16">
      <h2 class="mb-1 font-display text-2xl font-semibold text-foreground">Vælg klassetrin</h2>
      <p class="mb-8 text-muted-foreground">
        Klik på et klassetrin for at se alle tilgængelige læremidler.
      </p>
      <GradeRail variant="full" />
    </section>

    {/* Secondary navigation: by subject. */}
    <section class="pb-12 sm:pb-16">
      <h2 class="mb-1 font-display text-2xl font-semibold text-foreground">Eller find efter fag</h2>
      <p class="mb-8 text-muted-foreground">Se læremidler samlet for et helt fag på tværs af klassetrin.</p>
      <SubjectTiles />
    </section>

    {/* Everything not tied to a specific grade. */}
    <section class="pb-20">
      <a
        href="/other"
        class="ui-card ui-focus group flex items-center justify-between gap-4 p-5 transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/40"
      >
        <div class="flex items-center gap-4">
          <span
            class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary/12 text-primary"
            aria-hidden="true"
          >
            <span class="i-lucide-layout-grid text-xl"></span>
          </span>
          <div>
            <h3 class="font-display text-lg font-semibold text-card-foreground">Andre platforme</h3>
            <p class="text-sm text-muted-foreground">
              Øvrige ressourcer og opslagsværker uden bestemt klassetrin.
            </p>
          </div>
        </div>
        <span
          class="i-lucide-arrow-right text-xl text-muted-foreground transition-transform group-hover:translate-x-1"
          aria-hidden="true"></span>
      </a>
    </section>
  </div>
</Layout>
