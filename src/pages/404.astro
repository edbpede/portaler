---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Siden blev ikke fundet — Digitale læremidler">
  <div class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6">
    <span
      class="mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-primary/12 text-primary"
      aria-hidden="true"
    >
      <span class="i-lucide-compass text-3xl"></span>
    </span>
    <p class="font-display text-5xl font-bold text-foreground">404</p>
    <h1 class="mt-3 font-display text-2xl font-semibold text-foreground">
      Vi kunne ikke finde siden
    </h1>
    <p class="mt-3 text-muted-foreground">
      Linket er måske forældet, eller siden er flyttet. Gå tilbage til forsiden og find
      læremidlet via klassetrin eller fag.
    </p>
    <a
      href="/"
      class="ui-focus mt-8 inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 font-medium text-primary-foreground transition-opacity hover:opacity-90"
    >
      <span class="i-lucide-arrow-left" aria-hidden="true"></span>
      Til forsiden
    </a>
  </div>
</Layout>
