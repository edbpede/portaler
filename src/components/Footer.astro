---
import { Image } from "astro:assets";
import edbpedeSvg from "../assets/edbpede.svg";
import githubIcon from "../assets/github_icon.webp";
import agplv3Icon from "../assets/agplv3_icon.png";

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-line bg-paper-raised/60">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-4 py-6 sm:flex-row sm:px-6 lg:px-8"
  >
    <div class="flex items-center gap-4">
      <a
        href="https://edbpede.net"
        target="_blank"
        rel="noopener noreferrer"
        class="u-focus rounded-md opacity-80 transition-opacity hover:opacity-100"
        aria-label="edbpede.net"
      >
        <Image src={edbpedeSvg} alt="edbpede" width={30} height={30} />
      </a>
      <a
        href="https://github.com/edbpede/portaler"
        target="_blank"
        rel="noopener noreferrer"
        class="u-focus rounded-md opacity-80 transition-opacity hover:opacity-100"
        aria-label="Kildekode på GitHub"
      >
        <Image src={githubIcon} alt="GitHub" width={22} height={22} />
      </a>
      <a
        href="https://www.gnu.org/licenses/agpl-3.0.html"
        target="_blank"
        rel="noopener noreferrer"
        class="u-focus rounded-md opacity-80 transition-opacity hover:opacity-100"
        aria-label="AGPLv3-licens"
      >
        <Image src={agplv3Icon} alt="AGPLv3" width={48} height={39} />
      </a>
    </div>

    <p class="text-sm text-ink-faint">
      © {year} Portaler · til lærere på STR
    </p>
  </div>
</footer>
