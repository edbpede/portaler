---
import { Image } from "astro:assets";
import edbpede from "../assets/edbpede.svg";
import githubIcon from "../assets/github_icon.webp";
import agplv3Icon from "../assets/agplv3_icon.png";

const year = new Date().getFullYear();
---

<footer class="mt-20 border-t border-border">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-8 sm:flex-row sm:items-center sm:justify-between sm:px-6"
  >
    <div class="flex items-center gap-5">
      <a
        href="https://edbpede.net"
        target="_blank"
        rel="noopener noreferrer"
        class="ui-focus rounded opacity-80 transition-opacity hover:opacity-100"
        aria-label="edbpede"
      >
        <Image src={edbpede} alt="edbpede" width={32} height={32} class="h-8 w-8" />
      </a>
      <a
        href="https://github.com/edbpede/portaler"
        target="_blank"
        rel="noopener noreferrer"
        class="ui-focus rounded opacity-80 transition-opacity hover:opacity-100"
        aria-label="Kildekode på GitHub"
      >
        <Image src={githubIcon} alt="GitHub" width={24} height={24} class="h-6 w-6" />
      </a>
      <a
        href="https://www.gnu.org/licenses/agpl-3.0.html"
        target="_blank"
        rel="noopener noreferrer"
        class="ui-focus rounded opacity-80 transition-opacity hover:opacity-100"
        aria-label="AGPLv3-licens"
      >
        <Image src={agplv3Icon} alt="AGPLv3" width={52} height={42} class="h-7 w-auto" />
      </a>
    </div>

    <p class="text-sm text-muted-foreground">
      © {year} Portaler · Digitale læremidler for Strandgårdskolen
    </p>
  </div>
</footer>
