---
import { PHASES, gradeLabel, type PhaseId } from "../lib/grades";

interface Props {
  current?: number;
  variant?: "full" | "compact";
}

const { current, variant = "full" } = Astro.props;

// Literal class maps per phase so UnoCSS can statically extract them.
const phaseText: Record<PhaseId, string> = {
  indskoling: "text-indskoling",
  mellemtrin: "text-mellemtrin",
  udskoling: "text-udskoling",
};

const tileFull: Record<PhaseId, string> = {
  indskoling:
    "bg-indskoling/8 text-indskoling ring-1 ring-indskoling/20 hover:bg-indskoling/16 hover:ring-indskoling/40",
  mellemtrin:
    "bg-mellemtrin/8 text-mellemtrin ring-1 ring-mellemtrin/20 hover:bg-mellemtrin/16 hover:ring-mellemtrin/40",
  udskoling:
    "bg-udskoling/8 text-udskoling ring-1 ring-udskoling/20 hover:bg-udskoling/16 hover:ring-udskoling/40",
};

// Active = strong tint + solid ring + bold. Phase-coloured text on a tint of
// itself keeps AA contrast in both light and dark themes (white-on-bright-hue
// would fail AA for the lighter phases in dark mode).
const tileActive: Record<PhaseId, string> = {
  indskoling: "bg-indskoling/15 text-indskoling font-bold ring-2 ring-indskoling",
  mellemtrin: "bg-mellemtrin/15 text-mellemtrin font-bold ring-2 ring-mellemtrin",
  udskoling: "bg-udskoling/15 text-udskoling font-bold ring-2 ring-udskoling",
};

const compactTile: Record<PhaseId, string> = {
  indskoling: "text-indskoling hover:bg-indskoling/12",
  mellemtrin: "text-mellemtrin hover:bg-mellemtrin/12",
  udskoling: "text-udskoling hover:bg-udskoling/12",
};
---

{
  variant === "full" ? (
    <section aria-label="Vælg klassetrin" class="rise">
      {/* The journey line: one continuous hue ramp across the three phases. */}
      <div
        class="mb-8 h-1.5 w-full rounded-full bg-linear-to-r from-indskoling via-mellemtrin to-udskoling"
        aria-hidden="true"
      />

      <div class="grid gap-8 sm:grid-cols-3">
        {PHASES.map((phase) => (
          <div>
            <div class="mb-3 flex items-baseline justify-between">
              <h3 class={`font-display text-sm font-semibold tracking-wide uppercase ${phaseText[phase.id]}`}>
                {phase.label}
              </h3>
              <span class="text-xs text-muted-foreground">
                {phase.grades[0]}.–{phase.grades[phase.grades.length - 1]}. klasse
              </span>
            </div>
            <div class="flex flex-wrap gap-2.5">
              {phase.grades.map((grade) => (
                <a
                  href={`/grade/${grade}`}
                  aria-label={gradeLabel(grade)}
                  aria-current={current === grade ? "page" : undefined}
                  class={`ui-focus flex h-16 w-16 flex-col items-center justify-center rounded-2xl text-2xl font-semibold transition-all duration-200 hover:-translate-y-0.5 ${
                    current === grade ? tileActive[phase.id] : tileFull[phase.id]
                  }`}
                >
                  {grade}
                  <span class="text-[0.625rem] font-medium tracking-wide uppercase opacity-70">
                    klasse
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  ) : (
    <nav aria-label="Skift klassetrin" class="ui-card p-3">
      <div class="flex flex-wrap items-center gap-1.5">
        {PHASES.map((phase) => (
          <div class="flex flex-wrap items-center gap-1.5">
            <span class={`px-1.5 text-xs font-semibold tracking-wide uppercase ${phaseText[phase.id]}`}>
              {phase.label}
            </span>
            {phase.grades.map((grade) => (
              <a
                href={`/grade/${grade}`}
                aria-current={current === grade ? "page" : undefined}
                class={`ui-focus inline-flex h-9 min-w-9 items-center justify-center rounded-lg px-2 text-sm font-semibold transition-colors ${
                  current === grade
                    ? tileActive[phase.id]
                    : compactTile[phase.id]
                }`}
              >
                {grade}
              </a>
            ))}
          </div>
        ))}
      </div>
    </nav>
  )
}
